<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverage settings for `dotnet test`. Only Entra-PIM-Manager.Core is measured —
  the WPF App layer is intentionally excluded from the coverage gate
  (UI coverage is theatre; see CLAUDE.md test strategy).
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Include>[EntraPimManager.Core]*</Include>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
